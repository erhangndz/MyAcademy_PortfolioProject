@model About
@{
    ViewData["Title"] = "Hakkımızda Güncelle";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}


<form method="post">
    <input type="hidden" asp-for="Id" />
    <label>Başlık</label>
    <input type="text" asp-for="Title" class="form-control" required />
    <br />
    <label>Açıklama</label>
    <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
    <br />
    <label>Görsel Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" required />
    <br />
    <button class="btn btn-outline-dark">Güncelle</button>
</form>

