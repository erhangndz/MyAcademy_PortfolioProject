@{
    Layout = null;
}


<!DOCTYPE html>

<html class="light" lang="tr">

@await Component.InvokeAsync("_AdminLayoutHead") 



<body class="font-body-md text-body-md">
    @await Component.InvokeAsync("_AdminLayoutSidebar")
    <!-- TopNavBar -->
    <header class="h-16 fixed top-0 right-0 w-[calc(100%-260px)] bg-surface border-b border-outline-variant shadow-sm z-40 flex justify-between items-center px-lg">
        <div class="flex items-center gap-md flex-1">
            <div class="relative w-64">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">search</span>
                <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg py-1.5 pl-10 pr-4 text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary outline-none transition-all" placeholder="Proje ara..." type="text" />
            </div>
        </div>
        <div class="flex items-center gap-lg">
            <button class="relative p-2 rounded-full hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-on-surface">notifications</span>
                <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-surface"></span>
            </button>
            <div class="flex items-center gap-sm cursor-pointer hover:bg-surface-container p-1 rounded-lg transition-all">
                <img class="w-8 h-8 rounded-full border border-outline-variant" data-alt="A clean, minimalist circular avatar placeholder icon for a profile, styled with soft gradients of cool gray and white to match a professional dashboard interface." src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6yXRTnH-5I1Y9lwG7rqqAY0wQL5_dLBuYOcikgkmsLDaBHwYkfCWL0xY6uJTFxRJdRh5zFQVZQqKBqItDpW0WgAIzWdThP1O0XZGlNu17J7fXLIMLYSKxo1TbKI_MJDcP9qnTq4Eq6B2EXVwU-6O6vhDRhhTPyzE7XZ_MHqEwnYePUC0qtQvXKr-V3yw6ed5flvo9fN2T3wFQbiHTttuv8mEBz7hzDbUqF2wLRRtrUu6gkcqpZ28i6znDrnHTjyqD9Y8re81xWk2O" />
                <span class="material-symbols-outlined text-on-surface-variant">expand_more</span>
            </div>
        </div>
    </header>
    <!-- Main Content Area -->
    <main class="ml-[260px] pt-16 min-h-screen p-lg">
        <!-- Page Title & Stats -->
        
        <div class="container">
            <div class="mb-xl">
                <h1 class="font-h1 text-h1 text-on-surface mb-lg">@ViewData["Title"]</h1>

            </div>
            @RenderBody()
           
        </div>
    </main>
    
    <script>
        // Simple micro-interactions
        document.querySelectorAll('button, a').forEach(el => {
            el.addEventListener('mousedown', () => {
                el.classList.add('opacity-80');
            });
            el.addEventListener('mouseup', () => {
                el.classList.remove('opacity-80');
            });
        });

        // Search bar focus effect
        const searchInput = document.querySelector('input[type="text"]');
        searchInput.addEventListener('focus', () => {
            searchInput.parentElement.classList.add('w-80');
        });
        searchInput.addEventListener('blur', () => {
            searchInput.parentElement.classList.remove('w-80');
        });
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>