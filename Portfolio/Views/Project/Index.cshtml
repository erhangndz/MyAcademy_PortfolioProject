@model List<Project>
@{
    ViewData["Title"] = "Projelerim";
    Layout = "~/Views/AdminLayout/Layout.cshtml";
}


<table class="table table-hover table-bordered">
    <tr>
        <th>Görsel</th>
        <th>Proje Adı</th>
        <th>Proje Açıklaması</th>
        <th>Github Linki</th>
        <th>İşlemler</th>

    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td> <img src="@item.ImageUrl" style="height:50px;width:50px" />  </td>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td> <a href="@item.GithubUrl" target="_blank" class="btn btn-outline-dark">Github Url</a>  </td>
            <td>
                <button onclick="deleteProject(@item.Id)"  class="btn btn-outline-danger"> Sil</button>
                <a href="/Project/UpdateProject/@item.Id" class="btn btn-outline-info"> Güncelle</a>

            </td>
        </tr>
    }

</table>

<a href="/Project/CreateProject" class="btn btn-outline-dark">Yeni Proje Oluştur</a>


<script>

    function deleteProject(id){

            Swal.fire({
      title: "Silmek istediğinize emin misiniz?",
      text: "Bu işlemi geri alamazsınız!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Evet, Sil!",
      cancelButtonText: "İptal"
    }).then((result) => {
      if (result.isConfirmed) 
      
      window.location.href = "/Project/DeleteProject/" +id;
      
      
    });


    }


</script>